#: build/admin.js:1
#: src/screens/faq.js:15
msgid "I just enabled the plugin — why do my existing orders still show old numbers?"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:16
msgid "Existing orders are not modified automatically. The plugin applies custom order numbering only to new orders created after the settings are saved. To apply the same numbering format to existing orders, use the Renumerate Orders tool. This will reassign order numbers based on the current configuration."
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:19
msgid " I added a prefix or suffix, but it is not showing. What should I check?"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:21
msgid "Verify the following settings:"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:22
msgid "1. Prefix/Suffix option is enabled in the Prefix/Suffix Rules tab"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:23
msgid "2. The format includes {number} (for example: ORD-{number})"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:24
msgid "A static value without {number} will not generate a valid order number. After saving changes, create a test order to confirm the updated format."
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:28
msgid "What happens when I click “Renumber All Orders”? Can it be undone?"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:30
msgid "This action reassigns order numbers for all existing orders based on the current configuration."
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:31
msgid "There is no built-in option to undo this operation."
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:32
msgid "After execution:"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:33
msgid "1. All existing order numbers are replaced"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:34
msgid "2. Order references in emails and invoices may no longer match"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:35
msgid "3. External systems relying on order numbers may lose synchronization"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:39
msgid "I changed the Next Order Number and now see duplicate order numbers. How can this be fixed?"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:41
msgid "This occurs when the configured value overlaps with existing order numbers."
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:42
msgid "To resolve this:"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:43
msgid "1. Identify the latest order number in the store"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:44
msgid "2. Set “Next Order Number” to a value higher than the latest order"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:45
msgid "3. Save changes"
msgstr ""

#: build/admin.js:1
#: src/screens/faq.js:46
msgid "New orders will follow the corrected sequence."
